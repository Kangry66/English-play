// --- MÓDULO: LABORATORIO DE SONIDOS ---
function PhoneticsModule({ playAudio, theme, isDark, isFullscreen, toggleFullscreen }) {
    const [recordings, setRecordings] = useState({});
    const [recordingState, setRecordingState] = useState(null);
    const [aiTip, setAiTip] = useState(null);
    const [isLoading, setIsLoading] = useState(false);
    const mediaRecorderRef = useRef(null);
    const audioChunksRef = useRef([]);

    const getAITip = async (sound) => {
        setIsLoading(true);
        setAiTip(null);
        try {
            const prompt = `Como experto fonetista, da un consejo anatómico (boca, lengua, aire) para pronunciar correctamente el sonido "${sound.letter}" (${sound.s}) en inglés para un hispanohablante. Máximo 2 frases.`;
            const tip = await callGemini(prompt);
            setAiTip({ letter: sound.letter, tip });
        } catch (e) {
            setAiTip({ letter: sound.letter, tip: "Error al contactar con el tutor IA." });
        } finally {
            setIsLoading(false);
        }
    };

    const alphabet = [
        { L: 'A', s: '/eɪ/', w: 'Apple', sound: 'ah', desc: 'Nombre: "ei". Sonido: "a" abierta.' },
        { L: 'B', s: '/biː/', w: 'Banana', sound: 'buh', desc: 'Nombre: "bi". Sonido: "b" explosiva.' },
        { L: 'C', s: '/siː/', w: 'Cat', sound: 'kuh', desc: 'Nombre: "si". Sonido: "k" fuerte.' },
        { L: 'D', s: '/diː/', w: 'Dog', sound: 'duh', desc: 'Nombre: "di". Sonido: "d" dental.' },
        { L: 'E', s: '/iː/', w: 'Elephant', sound: 'eh', desc: 'Nombre: "i". Sonido: "e" seca.' },
        { L: 'G', s: '/dʒiː/', w: 'Green', sound: 'guh', desc: 'Nombre: "yi". Sonido: "g" de gato.' },
        { L: 'H', s: '/eɪtʃ/', w: 'House', sound: 'hhh', desc: 'Nombre: "eich". Sonido: aire suave.' },
        { L: 'R', s: '/ɑːr/', w: 'Red', sound: 'rrr', desc: 'Nombre: "ar". Sonido: lengua curva.' },
        { L: 'V', s: '/viː/', w: 'Very', sound: 'vvv', desc: 'Nombre: "vi". Sonido: vibración "v".' },
        { L: 'Z', s: '/ziː/', w: 'Zoo', sound: 'zzz', desc: 'Nombre: "zi". Sonido: abeja.' }
    ];

    const combinations = [
        { letter: 'CH', s: '/tʃ/', w: 'Cheese', audio: 'ch ch ch', desc: 'Explosión corta.' },
        { letter: 'SH', s: '/ʃ/', w: 'Shoe', audio: 'sh sh sh', desc: 'Como pedir silencio.' },
        { letter: 'TH (S)', s: '/θ/', w: 'Think', audio: 'th th th', desc: 'Aire entre dientes.' },
        { letter: 'TH (Z)', s: '/ð/', w: 'This', audio: 'the the the', desc: 'Vibra entre dientes.' },
    ];

    const startRecording = async (id) => {
        try {
            const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
            const recorder = new MediaRecorder(stream);
            mediaRecorderRef.current = recorder;
            audioChunksRef.current = [];
            recorder.ondataavailable = (e) => { if (e.data.size > 0) audioChunksRef.current.push(e.data); };
            recorder.onstop = () => {
                const audioBlob = new Blob(audioChunksRef.current, { type: 'audio/webm' });
                const audioUrl = URL.createObjectURL(audioBlob);
                setRecordings(prev => ({ ...prev, [id]: audioUrl }));
                stream.getTracks().forEach(track => track.stop());
            };
            recorder.start();
            setRecordingState(id);
        } catch (err) { console.error(err); }
    };

    const stopRecording = () => { if (mediaRecorderRef.current) { mediaRecorderRef.current.stop(); setRecordingState(null); } };
    const playRecording = (id) => { if (recordings[id]) { new Audio(recordings[id]).play(); } };

    const SoundCard = ({ item, idPrefix }) => {
        const cardId = `${idPrefix}-${item.letter || item.L}`;
        return (
            <div className={`p-4 rounded-3xl border transition-all duration-300 relative group ${theme.cardBg} ${theme.cardHover}`}>
                <button onClick={() => getAITip(item)} className="absolute top-3 right-3 text-indigo-400 opacity-0 group-hover:opacity-100 transition-opacity" title="Pedir consejo IA">
                    <Sparkles size={16} />
                </button>
                <span className={`text-4xl font-black block text-center mb-1 ${theme.textBold}`}>{item.letter || item.L}</span>
                <span className="text-indigo-400 font-mono text-sm block text-center mb-2">{item.s}</span>
                <p className={`text-[10px] text-center mb-4 h-8 leading-tight ${theme.textMuted}`}>{item.desc}</p>
                <div className="grid grid-cols-2 gap-2 w-full mt-auto">
                    <button onClick={() => playAudio(item.audio || item.sound || item.L)} className={`text-[10px] font-bold p-2.5 rounded-xl ${theme.btnAccent}`}>Sonido</button>
                    <button onClick={() => playAudio(item.w)} className={`text-[10px] font-bold p-2.5 rounded-xl ${theme.btnPrimary}`}>Palabra</button>
                    <button onClick={() => recordingState === cardId ? stopRecording() : startRecording(cardId)} className={`text-[10px] font-bold p-2.5 rounded-xl transition-all ${recordingState === cardId ? 'bg-rose-500 text-white animate-pulse' : theme.btnDanger}`}>
                        {recordingState === cardId ? 'Fin' : 'Grabar'}
                    </button>
                    <button onClick={() => playRecording(cardId)} disabled={!recordings[cardId]} className={`text-[10px] font-bold p-2.5 rounded-xl transition-all ${recordings[cardId] ? theme.btnSecondary : 'opacity-20 cursor-not-allowed'}`}>Mi Voz</button>
                </div>
            </div>
        );
    };

    return (
        <div className="animate-fade-in pb-10">
            <div className="flex justify-between items-start mb-8">
                <div>
                    <h2 className={`text-4xl font-black flex items-center gap-3 ${theme.textBold}`}><Mic className="text-rose-500" /> Laboratorio</h2>
                    <p className={`mt-2 ${theme.textMuted}`}>Usa los botones ✨ para consejos anatómicos de IA.</p>
                </div>
                <button onClick={toggleFullscreen} className={`p-3 rounded-2xl transition-all ${theme.cardBg} ${theme.textMuted} hover:text-indigo-400`}>
                    {isFullscreen ? <Minimize /> : <Maximize />}
                </button>
            </div>

            {isLoading && (
                <div className="mb-6 p-4 rounded-2xl bg-indigo-500/10 border border-indigo-500/30 flex items-center gap-3 text-indigo-400 animate-pulse">
                    <Loader2 className="animate-spin" /> <span className="text-sm font-bold">Consultando al Tutor IA...</span>
                </div>
            )}

            {aiTip && (
                <div className="mb-6 p-5 rounded-3xl bg-indigo-900/30 border border-indigo-500/30 animate-pop-in relative">
                    <button onClick={() => setAiTip(null)} className="absolute top-4 right-4 text-zinc-500 hover:text-white">&times;</button>
                    <h4 className="text-indigo-400 font-bold text-sm mb-2 flex items-center gap-2">
                        <Sparkles size={16} /> Consejo para "{aiTip.letter}"
                    </h4>
                    <p className="text-sm text-zinc-100 leading-relaxed italic">"{aiTip.tip}"</p>
                </div>
            )}

            <div className="space-y-16">
                <section>
                    <h3 className={`text-xl font-bold text-amber-500 border-l-4 border-amber-500 pl-4 mb-6`}>Abecedario Destacado</h3>
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-6">
                        {alphabet.map(item => <SoundCard key={item.L} item={item} idPrefix="abc" />)}
                    </div>
                </section>

                <section>
                    <h3 className={`text-xl font-bold text-violet-500 border-l-4 border-violet-500 pl-4 mb-6`}>Combinaciones Difíciles</h3>
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-6">
                        {combinations.map(item => <SoundCard key={item.letter} item={item} idPrefix="comb" />)}
                    </div>
                </section>
            </div>
        </div>
    );
}

