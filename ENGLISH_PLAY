    return (
        <div className="max-w-md mx-auto animate-fade-in">
            <div className="flex justify-between items-center mb-8">
                <h2 className={`text-3xl font-black ${theme.textBold}`}>Visual</h2>
                <div className="flex items-center gap-4">
                    <span className="bg-indigo-600/20 text-indigo-400 border border-indigo-500/30 px-5 py-2 rounded-full font-black text-sm shadow-xl">SCORE: {score}</span>
                    <button onClick={toggleFullscreen} className={`p-3 rounded-2xl transition-all ${theme.cardBg} ${theme.textMuted}`}>{isFullscreen ? <Minimize /> : <Maximize />}</button>
                </div>
            </div>
            <div className={`p-12 rounded-[2.5rem] border-2 border-zinc-800 text-center mb-10 shadow-2xl transition-all ${theme.cardBg}`}>
                <div className="text-9xl mb-8 animate-bounce-slow drop-shadow-[0_20px_30px_rgba(255,255,255,0.1)]">{target.emoji}</div>
                <p className="text-3xl font-black tracking-widest text-white uppercase">{target.es}</p>
            </div>
            <div className="grid grid-cols-1 sm:grid-cols-2 gap-5">
                {options.map(opt => (
                    <button key={opt.id} onClick={() => { if (opt.id === target.id) { setScore(s => s + 1); next(); } }} className={`p-6 rounded-3xl border-2 font-black text-xl transition-all transform active:scale-95 ${theme.cardBg} ${theme.cardHover} border-zinc-800`}>
                        {opt.en}
                    </button>
                ))}
            </div>
        </div>
    );
}

function LegoGame({ db, playAudio, theme, isDark }) {
    const [selected, setSelected] = useState([]);
    const [explanation, setExplanation] = useState(null);
    const [loading, setLoading] = useState(false);
    const pool = ["I", "want", "bread", "water", "like", "Apple", "You", "need", "Banana", "He", "likes", "Milk"];

    const analyzeGrammar = async () => {
        if (selected.length === 0) return;
        setLoading(true);
        try {
            const phrase = selected.join(" ");
            const prompt = `Analiza gramaticalmente la frase en inglés "${phrase}". Explica por qué se usa así brevemente en español. Máximo 2 frases.`;
            const res = await callGemini(prompt);
            setExplanation(res);
        } catch (e) {
            setExplanation("Error al analizar.");
        } finally {
            setLoading(false);
        }
    };

    return (
        <div className="max-w-2xl mx-auto animate-fade-in text-center">
            <h2 className={`text-3xl font-black mb-8 ${theme.textBold}`}>Lego Frases</h2>
            <div className={`p-10 rounded-[2.5rem] mb-10 shadow-2xl border transition-all ${theme.cardBg} border-indigo-500/20`}>
                <p className="text-indigo-400 text-xs font-black uppercase tracking-[0.2em] mb-4">Misión:</p>
                <p className="text-4xl font-black text-white">Yo quiero pan</p>
            </div>
            <div className={`min-h-[140px] border-2 border-dashed rounded-[2.5rem] p-8 mb-10 flex flex-wrap gap-4 justify-center items-center transition-all ${isDark ? 'bg-zinc-950/80 border-zinc-800 shadow-inner' : 'bg-slate-100 border-slate-300'}`}>
                {selected.length === 0 && <p className="text-zinc-700 font-bold uppercase tracking-widest text-sm">Arrastra las piezas aquí...</p>}
                {selected.map((w, i) => (
                    <button key={i} onClick={() => setSelected(selected.filter((_, idx) => idx !== i))} className={`px-8 py-4 rounded-2xl font-black text-xl shadow-2xl animate-pop-in ${theme.btnAccent}`}>{w}</button>
                ))}
            </div>
            <div className="flex flex-wrap gap-4 justify-center mb-10">
                {pool.map(w => (
                    <button key={w} onClick={() => setSelected([...selected, w])} className={`px-6 py-4 rounded-2xl border-2 font-bold shadow-xl transition-all transform hover:scale-105 active:scale-95 ${theme.cardBg} border-zinc-800 ${theme.cardHover}`}>{w}</button>
                ))}
            </div>

            <div className="flex flex-col gap-4">
                <button
                    onClick={analyzeGrammar}
                    disabled={selected.length === 0 || loading}
                    className={`flex items-center gap-2 mx-auto font-black px-10 py-4 rounded-full transition-all ${theme.btnSecondary} disabled:opacity-20`}
                >
                    {loading ? <Loader2 className="animate-spin" /> : <Sparkles size={20} />} ✨ ¿Por qué es así? IA
                </button>

                {explanation && (
                    <div className="p-5 rounded-3xl bg-amber-500/10 border border-amber-500/30 text-amber-200 text-sm italic animate-pop-in">
                        "{explanation}"
                    </div>
                )}

                <button onClick={() => { setSelected([]); setExplanation(null); }} className="text-rose-500 font-black uppercase tracking-widest text-xs hover:text-rose-400 mt-4">
                    Reiniciar Piezas
                </button>
            </div>
        </div>
    );
}

function ChatModule({ db, playAudio, theme, isDark }) {
    const [messages, setMessages] = useState([
        { role: 'assistant', content: 'Hi! I\'m your Gemini Tutor ✨. Let\'s speak in English. How are you today?' }
    ]);
    const [input, setInput] = useState('');
    const [loading, setLoading] = useState(false);
    const scrollRef = useRef(null);

    useEffect(() => {
        if (scrollRef.current) scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
    }, [messages]);

    const sendMessage = async () => {
        if (!input.trim() || loading) return;
        const userMsg = input;
        setInput('');
        setMessages(prev => [...prev, { role: 'user', content: userMsg }]);
        setLoading(true);

        try {
            const history = messages.map(m => `${m.role === 'user' ? 'Estudiante' : 'Tutor'}: ${m.content}`).join('\n');
            const prompt = `Continúa la conversación como un tutor de inglés. Si el estudiante cometió un error gramatical en su último mensaje, corrígelo amablemente. Responde siempre en inglés primero y una breve traducción al final.\n\nHistorial:\n${history}\nEstudiante: ${userMsg}`;

            const res = await callGemini(prompt);
            setMessages(prev => [...prev, { role: 'assistant', content: res }]);
        } catch (e) {
            setMessages(prev => [...prev, { role: 'assistant', content: 'Sorry, I had a connection error. Try again!' }]);
        } finally {
            setLoading(false);
        }
    };

    return (
        <div className="max-w-2xl mx-auto h-[75vh] flex flex-col">
            <h2 className={`text-3xl font-black mb-6 ${theme.textBold}`}>Chat IA ✨</h2>
            <div
                ref={scrollRef}
                className={`flex-1 overflow-y-auto p-8 rounded-[2.5rem] border-2 border-zinc-800 mb-6 space-y-6 shadow-inner scroll-smooth ${theme.cardBg}`}
            >
                {messages.map((m, i) => (
                    <div key={i} className={`flex ${m.role === 'user' ? 'justify-end' : 'justify-start'}`}>
                        <div className={`p-5 rounded-3xl max-w-[85%] shadow-2xl text-base leading-relaxed ${m.role === 'user' ? 'bg-indigo-600 text-white rounded-tr-none' : 'bg-zinc-800 text-zinc-100 rounded-tl-none border border-zinc-700'}`}>
                            <p className="whitespace-pre-wrap">{m.content}</p>
                            {m.role === 'assistant' && (
                                <button onClick={() => playAudio(m.content.split('\n')[0])} className="mt-3 text-[10px] font-black uppercase tracking-widest text-indigo-400 flex items-center gap-1 hover:text-indigo-300">
                                    <Volume2 size={12} /> Escuchar IA
                                </button>
                            )}
                        </div>
                    </div>
                ))}
                {loading && <div className="text-zinc-500 animate-pulse text-xs font-bold uppercase tracking-widest">IA está escribiendo...</div>}
            </div>
            <div className="flex gap-4">
                <input
                    value={input}
                    onChange={(e) => setInput(e.target.value)}
                    onKeyPress={(e) => e.key === 'Enter' && sendMessage()}
                    className={`flex-1 p-5 rounded-2xl border-2 border-zinc-800 focus:border-indigo-500 outline-none transition-all font-medium ${theme.inputBg}`}
                    placeholder="Habla conmigo en inglés..."
                />
                <button onClick={sendMessage} className={`p-5 rounded-2xl transition-all shadow-2xl ${theme.btnPrimary}`}>
                    <Send size={24} />
                </button>
            </div>
        </div>
    );
}

function DatabaseManager({ db, setDb, theme, showToast }) {
    const [isGenerating, setIsGenerating] = useState(false);
    const [topic, setTopic] = useState('');

    const generateWords = async () => {
        if (!topic.trim()) return;
        setIsGenerating(true);
        try {
            const prompt = `Genera un JSON con una lista de 3 palabras nuevas en inglés sobre el tema "${topic}". Formato: [{"en": "word", "es": "traducción", "pron": "fonética", "emoji": "un solo emoji"}].`;
            const schema = {
                type: "ARRAY",
                items: {
                    type: "OBJECT",
                    properties: {
                        en: { type: "STRING" },
                        es: { type: "STRING" },
                        pron: { type: "STRING" },
                        emoji: { type: "STRING" }
                    },
                    required: ["en", "es", "pron", "emoji"]
                }
            };

            const newWords = await callGeminiJSON(prompt, schema);
            const withIds = newWords.map(w => ({ ...w, id: Date.now() + Math.random(), category: "IA Generada" }));
            setDb(prev => [...withIds, ...prev]);
            showToast(`¡Añadidas 3 palabras sobre ${topic}!`);
            setTopic('');
        } catch (e) {
            showToast("Error al generar palabras.");
        } finally {
            setIsGenerating(false);
        }
    };

    return (
        <div className="max-w-4xl mx-auto">
            <div className="flex justify-between items-center mb-8">
                <h2 className={`text-3xl font-black ${theme.textBold}`}>Mi Base de Datos</h2>
                <div className="flex gap-3">
                    <input
                        value={topic}
                        onChange={(e) => setTopic(e.target.value)}
                        placeholder="Tema (ej: Espacio, Cocina...)"
                        className={`p-3 rounded-xl border border-zinc-800 text-sm focus:border-indigo-500 outline-none ${theme.inputBg}`}
                    />
                    <button
                        onClick={generateWords}
                        disabled={isGenerating || !topic}
                        className={`px-5 py-3 rounded-xl font-bold flex items-center gap-2 disabled:opacity-30 ${theme.btnPrimary}`}
                    >
                        {isGenerating ? <Loader2 className="animate-spin" /> : <Sparkles size={18} />} ✨ Sugerir IA
                    </button>
                </div>
            </div>
            <div className={`rounded-[2.5rem] border overflow-hidden shadow-2xl transition-all ${theme.cardBg} border-zinc-800`}>
                <div className="overflow-x-auto">
                    <table className="w-full text-left">
                        <thead className="bg-zinc-950">
                            <tr>
                                <th className="p-6 font-black text-indigo-400 uppercase text-xs tracking-[0.2em]">Inglés</th>
                                <th className="p-6 font-black text-zinc-500 uppercase text-xs tracking-[0.2em]">Español</th>
                                <th className="p-6 font-black text-amber-500 uppercase text-xs tracking-[0.2em]">Sonido</th>
                            </tr>
                        </thead>
                        <tbody>
                            {db.map(w => (
                                <tr key={w.id} className="border-t border-zinc-800/50 hover:bg-indigo-500/5 transition-colors group">
                                    <td className="p-6 font-bold flex items-center gap-4 text-white">
                                        <span className="text-2xl group-hover:scale-125 transition-transform duration-300">{w.emoji}</span>
                                        <div className="flex flex-col">
                                            <span className="text-lg">{w.en}</span>
                                            <span className="text-[10px] text-zinc-600 font-normal uppercase tracking-widest">{w.category}</span>
                                        </div>
                                    </td>
                                    <td className="p-6 text-zinc-400 font-medium">{w.es}</td>
                                    <td className="p-6 font-mono text-sm text-indigo-400/80 tracking-widest">/{w.pron}/</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    );
}
